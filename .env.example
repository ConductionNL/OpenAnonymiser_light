# OpenAnonymiser API – Environment configuratie
# Kopieer naar .env en pas aan

# Debug mode (false in productie)
DEBUG=true

# Server mode: development | staging | production
UVICORN_SERVER_MODE=development

# NLP configuratie
DEFAULT_LANGUAGE=nl
DEFAULT_NLP_ENGINE=spacy

# SpaCy model: nl_core_news_lg overal (lokaal venv, container, K8s).
# Wordt door uv sync geïnstalleerd vanuit pyproject.toml.
DEFAULT_SPACY_MODEL=nl_core_news_lg

# Plugin config — selecteert de flavor van de detector-set.
# Niet zetten = src/api/plugins.yaml (lokale dev-default).
# Containers zetten dit zelf: classic-image → plugins.classic.yaml,
# gpu-image → plugins.gpu.yaml. Override hier om een eigen config te
# mounten in een running container.
# PLUGINS_CONFIG=/app/src/api/plugins.classic.yaml

# Logging
LOG_DIR=logs
